# Variables de entorno de burgerjazz-chatbot (plantilla — SIN valores reales).
# En producción se configuran en el panel de Vercel. Copia a .env.local para dev.

# --- IA ---
ANTHROPIC_API_KEY=          # API key de Anthropic (chat, informes, learn, sync)

# --- Base de datos (Neon/Postgres) ---
DATABASE_URL=               # Connection string de Neon (la usa api/_db.js)

# --- Auth del panel ---
# Multiusuario: JSON {"Marta":"clave","Nacho":"clave"}.
# Las claves pueden ir en claro o hasheadas (scrypt) — genera el hash con:
#   DASHBOARD_USERS='{"Marta":"clave"}' node scripts/hash-dashboard-users.js
DASHBOARD_USERS=
DASHBOARD_KEY=              # (Opcional) clave única compartida, alternativa/legacy

# --- Crons ---
# Vercel inyecta "Authorization: Bearer <CRON_SECRET>" en los crons si existe.
CRON_SECRET=
LEARN_KEY=                 # Clave para disparar crons manualmente (?key=...)

# --- Tokens de sesión del widget (poll/delete) ---
SESSION_SECRET=            # Secreto para firmar los tokens HMAC de sesión

# --- Notificaciones push (web-push / VAPID) ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# --- Email y Slack (alertas e informes) ---
RESEND_API_KEY=            # Envío de emails vía Resend
SLACK_WEBHOOK_URL=         # (Opcional) webhook para alertas en Slack

# --- Google Business Profile (respuestas a reseñas — api/_gbp.js) ---
# Si faltan, el cron cron-reviews y el panel /resenas.html quedan INERTES
# (devuelven "not_configured") — se pueden desplegar sin romper nada.
# Scope OAuth para el refresh token: https://www.googleapis.com/auth/business.manage
GBP_CLIENT_ID=             # OAuth client id (Google Cloud → Credenciales)
GBP_CLIENT_SECRET=         # OAuth client secret
GBP_REFRESH_TOKEN=         # Refresh token de la cuenta que gestiona los locales de BJ
GBP_LOCATIONS=             # JSON { "<accountId>/<locationId>": "Chamberí", ... } — BJ tiene 2 cuentas (Majadahonda va en la PERSONAL)
GBP_ACCOUNT_ID=            # (opcional) cuenta por defecto para claves sin prefijo de cuenta
